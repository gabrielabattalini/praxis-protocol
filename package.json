{
  "name": "praxis-protocol",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --max-old-space-size=8192 node_modules/next/dist/bin/next dev",
    "build": "node --max-old-space-size=8192 node_modules/next/dist/bin/next build",
    "start": "next start",
    "lint": "eslint",
    "test:security": "node --test --experimental-strip-types \"tests/security/*.test.mjs\"",
    "test:units": "node --test \"tests/notifications/*.test.mjs\" \"tests/store/*.test.mjs\"",
    "test": "npm run test:units",
    "import:usda": "node scripts/import-usda-foods.mjs",
    "import:tbca": "node scripts/import-tbca-foods.mjs",
    "verify:shopping-links": "node scripts/verify-shopping-links.mjs",
    "telegram:webhook": "node scripts/setup-telegram-webhook.mjs"
  },
  "overrides": {
    "@clerk/backend": "3.2.8",
    "@clerk/shared": "4.6.0"
  },
  "dependencies": {
    "@clerk/localizations": "^4.2.3",
    "@clerk/nextjs": "^7.0.6",
    "@hookform/resolvers": "^5.2.2",
    "axios": "^1.15.0",
    "cheerio": "^1.2.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.577.0",
    "next": "16.2.3",
    "playwright": "^1.59.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.72.0",
    "stripe": "^22.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
