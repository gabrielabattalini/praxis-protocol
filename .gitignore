# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.data/
/.sources/
/.tmp-video-frames/
*.log

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# clerk configuration (can include secrets)
/.clerk/

# local dev tooling (Claude Code / agents / temp artifacts)
.agents/
.claude/
.tools/
.stitch/
.playwright-cli/
.openclaude-profile.json
.tmp-*
*.pid
lint-results.txt

# local test outputs / screenshots
output/
output-*.png
.codex-nutrition-check.png
test-results/
tmp/
tmp-*

# mobile audit harness output
/audit-artifacts/
